<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#1E293B"
    android:paddingHorizontal="10dp"
    android:paddingVertical="6dp"
    android:layout_marginBottom="4dp">

    <View
        android:id="@+id/widget_item_color_bar"
        android:layout_width="4dp"
        android:layout_height="36dp"
        android:background="#6366F1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="6dp">

        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Habit Title"
            android:textColor="#F8FAFC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/widget_item_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30m target"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:singleLine="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_item_ticker"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:textColor="#10B981"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingEnd="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_item_btn_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▶ Start"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:background="#6366F1" />
</LinearLayout>
